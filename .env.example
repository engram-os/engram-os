# ─── MANDATORY — system will not start correctly without these ────────────────

# Fernet key shared across ALL containers (os_layer, dashboard).
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENGRAM_ENCRYPTION_KEY=

# Master API key for authenticating requests to the Brain API.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENGRAM_API_KEY=

# HMAC secret for tamper-evident audit log chain.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
AUDIT_HMAC_SECRET=

# Pin all containers to the same user UUID (prevents divergent identity.json).
# Generate: python3 -c "import uuid; print(uuid.uuid4())"
ENGRAM_USER_ID=


# ─── OPTIONAL — runtime defaults are used when not set ───────────────────────

# Ollama base URL (default: http://host.docker.internal:11434)
# OLLAMA_HOST=http://host.docker.internal:11434

# Ollama model to use for all LLM inference (default: llama3.1:latest)
# OLLAMA_MODEL=llama3.1:latest


# ─── PROJECT MANAGEMENT INTEGRATIONS (optional) ──────────────────────────────

# Linear API key — enables Daily Briefing task fetch
# LINEAR_KEY=lin_api_...

# Jira — enables Daily Briefing task fetch
# JIRA_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_TOKEN=ATATT3...


# ─── LEGACY / UNUSED — kept for reference, not read by the system ─────────────
# DB_PASSWORD=
# OPENAI_API_KEY=
# PORT=3000
